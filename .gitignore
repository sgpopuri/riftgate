# Optional local-only scratch (never commit secrets)
*.local.md
.local/
notes/private/
config/workspace.local.env
.cargo/config.toml

# Rust build / target output
target/
**/*.rs.bk
Cargo.lock.bak

# mdbook output
book/

# cargo-fuzz scratch
fuzz/target/
fuzz/corpus/
fuzz/artifacts/

# Local benchmark artefacts
criterion/
flamegraph.svg
perf.data
perf.data.old

# Local staged eBPF object artifacts (v0.4 Aya workflow)
crates/riftgate-obs-bpf/obj/*.bpf.o

# OS noise
.DS_Store
Thumbs.db

# Editor / agent scratch (`.cursor/`, `.vscode/`, and `.github/` are not ignored so
# shared workspace rules, Copilot/Cursor hints, Actions, and PR templates can live in git.)
.idea/
.aider*
*.swp
*.swo
