# Copy to config/workspace.local.env and fill in local-only values.
# Do not commit the real file.
#
# Lima VM profile (current default — see AGENTS.md §11.5 and RUNBOOK.md).
# Lima sets the guest hostname to lima-<name>; the VM name in lima/riftgate.yaml is "riftgate".
RIFTGATE_ENV_HOST_FQDN="lima-riftgate.local"
RIFTGATE_ENV_HOST_SHORT="lima-riftgate"
RIFTGATE_ENV_TOOLCHAIN="stable"

# Backward-compatible aliases — if you have an existing config/workspace.local.env
# with RIFTGATE_SANDBOX_* names, they will still work; scripts fall back to them
# if the RIFTGATE_ENV_* names are not set.
# RIFTGATE_SANDBOX_HOST_FQDN="<environment host fqdn>"
# RIFTGATE_SANDBOX_HOST_SHORT="<environment host short name>"
# RIFTGATE_SANDBOX_TOOLCHAIN="<locally installed rust toolchain>"

# Cargo registry proxy — NOT needed for the Lima profile.
# crates.io is directly accessible from the Lima VM via the macOS host network.
# Leave these unset; do not run scripts/render-cargo-config for the Lima profile.
# RIFTGATE_CARGO_REGISTRY_NAME="<internal registry name>"
# RIFTGATE_CARGO_REGISTRY_INDEX_URL="<internal sparse index url>"

# Rust binary/source tarballs — NOT needed for the Lima profile.
# Rust is installed via rustup inside the Lima VM (provision: user in lima/riftgate.yaml).
# RIFTGATE_INTERNAL_RUST_BIN_TARBALL="<internal rust binary tarball path>"
# RIFTGATE_INTERNAL_RUST_SRC_TARBALL="<internal rust source tarball path>"

# Docker registry proxy — NOT needed for the Lima profile.
# The Lima VM has direct internet access for docker image pulls.
# RIFTGATE_DOCKER_REGISTRY_PROXY="<internal docker registry proxy host>"
# RIFTGATE_DOCKER_REGISTRY_ALT="<optional internal docker registry host>"

# OTel collector image — use contrib variant (includes glibc); core image is scratch-based and unusable.
RIFTGATE_OTEL_COLLECTOR_IMAGE="otel/opentelemetry-collector-contrib:<version>"